# Local account/token prototype.
# Production token credits should be added by Stripe webhooks.

# Optional production storage. Required on serverless hosting for persistent
# accounts, sessions, tokens, and bookings.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional emails. Used for account creation and booking confirmation.
# The sender domain must be verified by the email provider.
RESEND_API_KEY=
EMAIL_FROM="DojoMath <reservation@dojomath.fr>"
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=mkkurban9@gmail.com
DOJOMATH_MEET_LINK=https://meet.google.com/xxx-xxxx-xxx

# Server-only token used for protected operational endpoints such as manual
# token crediting and detailed health checks. Never expose it with NEXT_PUBLIC_.
DOJOMATH_ADMIN_TOKEN=

# Optional public origin used by same-origin checks on API mutations.
NEXT_PUBLIC_SITE_URL=https://www.domaths.fr

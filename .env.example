# Local account/token prototype.
# Production token credits should be added by Stripe webhooks.

# Optional production storage. Required on serverless hosting for persistent
# accounts, sessions, tokens, and bookings.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional emails. Used for account creation and booking confirmation.
# The sender domain must be verified by the email provider.
RESEND_API_KEY=
EMAIL_FROM="DojoMath <reservation@dojomath.fr>"
